    <script type="text/javascript">
        $(document).ready(function () {
            var ChangeInPage = false;

            $('#ctl00_ContentPlaceHolder1_ddlInstitute_chosen').click(function () {
                ChangeInPage = true;
                var instcdType = $('#ctl00_ContentPlaceHolder1_ddlInstitute').val().substring(0, 1);
                if (instcdType != 0)
                    $('#ctl00_ContentPlaceHolder1_chkInstituteList_' + (parseInt(instcdType) - 1)).prop('checked', true);
            });

            $('#ctl00_ContentPlaceHolder1_ddlBranch_chosen').click(function () {
                ChangeInPage = true;
                var brcdType = $('#ctl00_ContentPlaceHolder1_ddlBranch').val().substring(0, 1);
                if (brcdType != 0)
                    $('#ctl00_ContentPlaceHolder1_chkCourseDuration_' + (parseInt(brcdType) - 4)).prop('checked', true);
            });

            function FilterSeat() {
                if (!ChangeInPage)
                    return;
                var instType, courseType, instcd, brcd;
                var cInsttype = "";
                var cInstcd = "";
                var cBrcd = "";
                var preResult = false;
                var AllRows = $('#GridView1 TR');
                var show = true;
                var i = 1;
                var RowInDisplay = 0;
                var preInstcd = "";
                var preBrcd = "";
                var currRow = AllRows.first();
                try {
                    RowInDisplay = 0;
                    for (i = 3; i <= AllRows.length - 2; i++) {
                        show = true;
                        currRow = AllRows.eq(i);
                        cInstcd = currRow.find('#lblInstCode').text();
                        if (!$('#ctl00_ContentPlaceHolder1_chkInstituteList_0').is(":checked")) {
                            if (cInstcd.substring(0, 1) == "1")
                                show = false;
                        }

                        if (show && !$('#ctl00_ContentPlaceHolder1_chkInstituteList_1').is(":checked")) {
                            if (cInstcd.substring(0, 1) == "2")
                                show = false;
                        }

                        if (show && !$('#ctl00_ContentPlaceHolder1_chkInstituteList_2').is(":checked")) {
                            if (cInstcd.substring(0, 1) == "3")
                                show = false;
                        }

                        if (show && !$('#ctl00_ContentPlaceHolder1_chkInstituteList_3').is(":checked")) {
                            if (cInstcd.substring(0, 1) == "4")
                                show = false;
                        }

                        cBrcd = currRow.find('#lblAcademicProgramCode').text();

                        if (show && !$('#ctl00_ContentPlaceHolder1_chkCourseDuration_0').is(":checked")) {
                            if (cBrcd.substring(0, 1) == "4")
                                show = false;
                        }

                        if (show && !$('#ctl00_ContentPlaceHolder1_chkCourseDuration_1').is(":checked")) {
                            if (cBrcd.substring(0, 1) == "5")
                                show = false;
                        }

                        instcd = $('#ctl00_ContentPlaceHolder1_ddlInstitute').val();
                        if (show && instcd != "0" && instcd != cInstcd) {
                            show = false;
                        }

                        brcd = $('#ctl00_ContentPlaceHolder1_ddlBranch').val();
                        if (show && brcd != "0" && brcd != cBrcd) {
                            show = false;
                        }


                        if (show) {
                            if (preInstcd != cInstcd || preBrcd != cBrcd) {
                                RowInDisplay = RowInDisplay + 1;
                                preInstcd = cInstcd;
                                preBrcd = cBrcd;
                            }
                            currRow.show();
                            currRow.next().show();
                            currRow.next().next().show();

                        }
                        else {

                            currRow.hide();
                            currRow.next().hide();
                            currRow.next().next().hide();
                        }
                        i = i + 2;
                    }

                } catch (e) {
                    alert(e.Message);
                }
                if (RowInDisplay == 0) {
                    alert("Sorry no record exists on selected criteria!");
                }
                $('#ctl00_ContentPlaceHolder1_lbltotal').html(RowInDisplay);
                return;
            }

        });

    </script>

    


